\details{
Recommended per-tick call order, by model:

\describe{
\item{SIR}{\code{step_infectious_ir()}, then \code{step_transmission_si()}}
\item{SEIR}{\code{step_infectious_ir()}, \code{step_exposed_ei()}, \code{step_transmission_se()}}
